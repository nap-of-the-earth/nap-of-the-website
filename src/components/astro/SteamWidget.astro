---
interface Props {
  appId: string | number;
}

const { appId } = Astro.props;
---

<iframe
  src={`https://store.steampowered.com/widget/${appId}/`}
  frameborder="0"
  width="100%"
  height="190"
  style="border-radius: 8px; border: 1px solid var(--color-border); margin: 2rem 0; display: block; overflow: hidden;"
  loading="lazy"
  scrolling="no"
></iframe>
